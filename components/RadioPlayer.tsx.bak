"use client";

import { useEffect, useRef, useState } from "react";

const STREAM_URL = "https://c4.siar.us:8092/live";
const ICECAST_URL = "https://c4.siar.us:8092/status-json.xsl";

type Meta = {
  title: string;
  artist: string;
  listeners: number;
};

export default function RadioPlayer() {
  const audioRef = useRef<HTMLAudioElement | null>(null);

  const [playing, setPlaying] = useState(false);
  const [loading, setLoading] = useState(false);

  const [meta, setMeta] = useState<Meta>({
    title: "Radio Sehati",
    artist: "-",
    listeners: 0,
  });

  const [cover, setCover] = useState("/cover.jpg");

  // ================= PLAY =================
  const togglePlay = async () => {
    const audio = audioRef.current;
    if (!audio) return;

    try {
      if (!playing) {
        setLoading(true);
        await audio.play();
        setPlaying(true);
      } else {
        audio.pause();
        setPlaying(false);
      }
    } finally {
      setLoading(false);
    }
  };

  // ================= ICECAST =================
  const fetchMeta = async () => {
    try {
      const res = await fetch(ICECAST_URL + "?t=" + Date.now());
      const data = await res.json();

      const source = Array.isArray(data?.icestats?.source)
        ? data.icestats.source[0]
        : data?.icestats?.source;

      const raw = source?.title || "Radio Sehati";

      let artist = "-";
      let title = raw;

      if (raw.includes(" - ")) {
        const parts = raw.split(" - ");
        artist = parts[0];
        title = parts.slice(1).join(" - ");
      }

      setMeta({
        artist,
        title,
        listeners: source?.listeners || 0,
      });

      fetchCover(artist, title);
    } catch {
      // silent fail (production safe)
    }
  };

  // ================= COVER =================
  const fetchCover = async (artist: string, title: string) => {
    try {
      const query = `${artist} ${title}`.trim();

      const res = await fetch(
        `https://itunes.apple.com/search?term=${encodeURIComponent(query)}&entity=song&limit=1`
      );

      const data = await res.json();

      const img = data?.results?.[0]?.artworkUrl100;

      if (img) {
        setCover(img.replace("100x100", "600x600"));
      }
    } catch {
      // fallback
    }
  };

  useEffect(() => {
    fetchMeta();
    const i = setInterval(fetchMeta, 8000);
    return () => clearInterval(i);
  }, []);

  return (
    <div className="flex justify-center p-4">
      <div className="w-full max-w-md bg-white/20 backdrop-blur-xl rounded-2xl p-6 shadow-xl text-center">

        <h1 className="text-xl font-bold">
          Radio Streaming Sehati
        </h1>

        {/* COVER */}
        <img
          src={cover}
          className="w-52 h-52 mx-auto rounded-xl mt-4 shadow-lg"
        />

        {/* META */}
        <div className="mt-4">
          <p className="text-lg font-semibold">{meta.title}</p>
          <p className="text-sm opacity-80">{meta.artist}</p>
          <p className="text-xs mt-2">
            {meta.listeners} listeners
          </p>
        </div>

        {/* BUTTON */}
        <button
          onClick={togglePlay}
          className="mt-5 w-full py-3 rounded-xl bg-amber-500 text-white font-semibold"
        >
          {loading ? "Connecting..." : playing ? "Pause" : "Play"}
        </button>

        {/* AUDIO */}
        <audio
          ref={audioRef}
          src={STREAM_URL}
          preload="none"
        />
      </div>
    </div>
  );
}